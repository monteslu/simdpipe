{
  "name": "simdpipe",
  "version": "0.3.0",
  "description": "Portable SIMD software rasterizer (WASM + 128-bit SIMD). Isomorphic Node + browser. A member of the Mesa -pipe family (softpipe/llvmpipe/lavapipe), built for speed by doing less work.",
  "type": "module",
  "main": "./lib/index.mjs",
  "exports": {
    ".": "./lib/index.mjs"
  },
  "files": [
    "lib/",
    "dist/simdpipe.mjs",
    "dist/simdpipe.wasm",
    "dist/simdpipe-threads.mjs",
    "dist/simdpipe-threads.wasm",
    "examples/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bash src/build.sh",
    "smoke": "node bench/smoke.mjs",
    "bench": "node bench/run.mjs",
    "bench:threads": "node bench/threads.mjs",
    "bench:jit": "node bench/jit-spike.mjs",
    "bench:jit-simd": "node bench/jit-simd-spike.mjs",
    "bench:fidelity": "node bench/fidelity.mjs",
    "bench:pool": "node bench/pool.mjs",
    "cube": "node bench/cube.mjs",
    "program": "node bench/program-test.mjs",
    "glsl": "node bench/glsl-test.mjs",
    "jit-shader": "node bench/jit-shader-test.mjs",
    "jit-texture": "node bench/jit-texture-test.mjs",
    "compete": "node bench/compete/run-all.mjs",
    "compete:build-native": "gcc -O3 -march=native -o bench/compete/native-raster bench/compete/native-raster.c -lm",
    "test": "node bench/smoke.mjs && node bench/program-test.mjs && node bench/glsl-test.mjs && node bench/jit-shader-test.mjs && node bench/jit-texture-test.mjs && node bench/cube.mjs"
  },
  "keywords": [
    "software-rasterizer",
    "rasterizer",
    "renderer",
    "webgl",
    "opengl",
    "gl",
    "wasm",
    "webassembly",
    "simd",
    "graphics",
    "framebuffer",
    "isomorphic",
    "llvmpipe",
    "softpipe"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
